# ─── EcoTrack Environment Configuration ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# All variables are optional — the app will start with sensible defaults.

# Google Gemini API key for AI chat and personalised insights.
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps API key (used only for masked display in /api/config).
# The frontend uses free OpenStreetMap + Leaflet, so this is optional.
MAPS_API_KEY=your_google_maps_api_key_here

# HTTP port the server listens on (default: 8000).
PORT=8000

# Path to the JSON file used for persistent storage (default: data/user_data.json).
DATA_FILE=data/user_data.json

# Comma-separated list of allowed CORS origins.
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
